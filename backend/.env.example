# Copy this to .env and fill in your values.
# Never commit .env to version control.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vigil

# Public origin the crisis page is served at, used to build each person's QR
# URL (f"{BASE_URL}/c/{slug}"). For a phone to scan and open it, set this to a
# LAN-reachable address (e.g. http://192.168.1.20:8000) — localhost won't work
# from another device. Defaults to http://localhost:8000 if unset.
BASE_URL=http://localhost:8000
